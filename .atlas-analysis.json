  "keyFeatures": [
    "Google Drive integration with real-time change detection",
    "TMDB metadata fetching with posters and backdrops",
    "MPV media player integration with IPC control",
    "TV show organization with season and episode tracking",
    "Resume playback with progress tracking",
    "Watch Together synchronization with WebSocket",
    "Social features: friends, activity feed, and chat",
    "System tray with Windows notifications",
    "Monochrome UI with Radix UI and Framer Motion"
  ],
  "publicApiSurface": [
    "get_library - Retrieve media library items",
    "scan_cloud_library - Scan Google Drive for media",
    "play_media - Launch MPV player with media file",
    "update_resume_position - Save playback progress",
    "search_tmdb - Search TMDB for metadata",
    "fix_match - Manually correct metadata match",
    "get_episodes - Retrieve TV show episodes",
    "connect_google_drive - OAuth authentication flow",
    "get_drive_account_info - Get Drive account details",
    "create_watch_together_room - Create synchronized viewing session",
    "join_watch_together_room - Join existing room",
    "send_friend_request - Send friend request",
    "get_activity_feed - Retrieve social activity",
    "set_privacy_settings - Configure privacy options"
  ]
